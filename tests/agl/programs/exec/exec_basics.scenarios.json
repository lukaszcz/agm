{
  "scenarios": [
    {
      "name": "simple_name",
      "inputs": {"name": "world"},
      "expect": {
        "stdout_contains": [
          "hi world\n",
          "padded\nend marker\n",
          "43\n",
          "\"k\"",
          "\"a\"",
          "\"b\""
        ]
      }
    },
    {
      "name": "hostile_name_is_quoted_not_executed",
      "inputs": {"name": "it's tricky; echo HACK"},
      "expect": {
        "stdout_contains": ["hi it's tricky; echo HACK\n", "padded\nend marker\n", "43\n"],
        "stdout_not_contains": ["\nHACK"]
      }
    },
    {
      "name": "name_with_spaces_and_quotes",
      "inputs": {"name": "two words \"quoted\""},
      "expect": {
        "stdout_contains": ["hi two words \"quoted\"\n", "43\n"]
      }
    }
  ]
}
