{
  "scenarios": [
    {
      "name": "simple_arg_printed",
      "params": {"arg": "hello", "k": 4},
      "shell": [
        {"command": "printf '%s|' hello", "stdout": "hello|"},
        {"command": "printf '%s' 4", "stdout": "4"}
      ],
      "expect": {
        "stdout": "hello|\n4\n"
      }
    },
    {
      "name": "negative_int",
      "params": {"arg": "test", "k": -12},
      "shell": [
        {"command": "printf '%s|' test", "stdout": "test|"},
        {"command": "printf '%s' -12", "stdout": "-12"}
      ],
      "expect": {
        "stdout": "test|\n-12\n"
      }
    },
    {
      "name": "space_causes_word_split",
      "params": {"arg": "a b", "k": 0},
      "shell": [
        {"command": "printf '%s|' a b", "stdout": "a|b|"},
        {"command": "printf '%s' 0", "stdout": "0"}
      ],
      "expect": {
        "stdout": "a|b|\n0\n"
      }
    }
  ]
}
