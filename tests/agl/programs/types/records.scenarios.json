{
  "scenarios": [
    {
      "name": "severe_issue_escalates",
      "params": {"min_severity": 4},
      "agents": {
        "tracker": [
          "{\"title\": \"Crash on save\", \"severity\": 5, \"weight\": 1.25, \"tags\": [\"bug\"], \"extra\": {\"seen\": 2}, \"author\": {\"name\": \"Bo\", \"active\": false}}"
        ]
      },
      "expect": {
        "stdout": "Missing tests\n3\n0.5\nAda\ntrue\nCrash on save\n5\nescalate\n",
        "calls": {"tracker": 1}
      }
    },
    {
      "name": "mild_issue_ignored",
      "params": {"min_severity": 4},
      "agents": {
        "tracker": [
          "{\"title\": \"Typo\", \"severity\": 1, \"weight\": 0.1, \"tags\": [], \"extra\": null, \"author\": {\"name\": \"Cy\", \"active\": true}}"
        ]
      },
      "expect": {
        "stdout": "Missing tests\n3\n0.5\nAda\ntrue\nTypo\n1\nignore\n",
        "calls": {"tracker": 1}
      }
    },
    {
      "name": "lenient_default_extracts_chatty_reply",
      "params": {"min_severity": 2},
      "agents": {
        "tracker": [
          "Sure! Here is the issue you asked for:\n```json\n{\"title\": \"Flaky test\", \"severity\": 2, \"weight\": 0.75, \"tags\": [\"ci\"], \"extra\": {}, \"author\": {\"name\": \"Di\", \"active\": true}}\n```\nLet me know if you need more."
        ]
      },
      "expect": {
        "stdout": "Missing tests\n3\n0.5\nAda\ntrue\nFlaky test\n2\nescalate\n",
        "calls": {"tracker": 1}
      }
    },
    {
      "name": "missing_field_aborts_by_default",
      "params": {"min_severity": 2},
      "agents": {
        "tracker": ["{\"title\": \"No severity\"}"]
      },
      "expect": {
        "stdout": "Missing tests\n3\n0.5\nAda\ntrue\n",
        "calls": {"tracker": 1},
        "raises": {
          "type": "AgentParseError",
          "fields": {"agent": "tracker", "attempts": 1}
        }
      }
    }
  ]
}
