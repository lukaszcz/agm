# Renderer selection: boundary-marked default for text, raw / json / bullets
# overrides.
enum Review
  | Fail(issues: list[text])
  | Pass

input artifact

let issues = ["missing tests", "unclear API"]
let review: Review = Fail(issues: issues)

let a = prompt "default: ${artifact}"
let b = prompt "raw: ${artifact as raw}"
let c = prompt "json list: ${issues as json}"
let d = prompt "bullets:\n${issues as bullets}"
let e = prompt "review: ${review as json}"
print "sent"
