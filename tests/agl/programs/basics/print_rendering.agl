# print console rendering: text verbatim, scalars as scalar text,
# structured values in AgL-native form; print uses single-line rendering.
record Pair
  name: text
  score: int

enum Verdict
  | Good
  | Bad(reason: text)

param n: int

print "plain text line"
print "two\nlines"
print 42
print(-7)
print 2.5
print true
print false
print n
print ["a", "b"]
print {alpha: 1, beta: 2}
print(Pair(name = "x", score = 3))
print(Verdict.Bad(reason = "slow"))
let j: json = null
print j
# JSON opt-in via "as json": print still emits single-line render output.
print(Pair(name = "x", score = 3) as json)
print(Verdict.Bad(reason = "slow") as json)
