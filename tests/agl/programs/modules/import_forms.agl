# Modules: import forms in combination with functions and casts. Exercises an
# open import, an alias, a `using … as` rename, a wildcard alias facade,
# qualified `::` access, a `private` helper reached only through its public
# wrapper, and `::name` self-reference bypassing a shadowing parameter.
open import num/arith
import num/stats as st
import text/format using label, shout as yell
import lib/* as L

param x: int
param y: int

# A top-level def in the entry, deliberately shadowed below by a parameter.
def tag() -> int = 7

# `::tag()` bypasses the `tag` parameter to call this module's own top-level def.
def bump(tag: int) -> int = tag + ::tag()

# Open import: `add` and `label` are available unqualified.
print(label("sum", add(x, y)))

# `using shout as yell`: only the renamed `yell` is valid.
print(yell("go"))

# Qualified-as access into num.stats.
print(st::max2(x, y) as text)
print(st::min2(x, y) as text)

# A private helper reached only through its public wrapper.
print(via_secret(x) as text)

# The wildcard alias is a merged facade filtered by the selected member.
print(L::alpha())
print(L::beta())

# Self-reference inside a shadowing parameter scope.
print(bump(x) as text)
