{
  "scenarios": [
    {
      "name": "positive_values",
      "params": {"a": 1, "b": 2, "c": 3},
      "expect": {
        "stdout": "3\n6\ntrue\nfalse\n3\nabc\n2\n6\nroot 1\n"
      }
    },
    {
      "name": "negative_and_zero_values",
      "params": {"a": -5, "b": 0, "c": 10},
      "expect": {
        "stdout": "3\n5\ntrue\nfalse\n3\nabc\n2\n5\nroot -5\n"
      }
    },
    {
      "name": "all_equal_values",
      "params": {"a": 7, "b": 7, "c": 7},
      "expect": {
        "stdout": "3\n21\ntrue\nfalse\n3\nabc\n2\n21\nroot 7\n"
      }
    }
  ]
}
