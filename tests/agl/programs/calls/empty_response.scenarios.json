{
  "scenarios": [
    {
      "name": "empty_text_is_valid",
      "agents": {"ask": [""], "prompter": ["7"]},
      "expect": {
        "stdout": "\nafter\n7\n",
        "calls": {"ask": 1, "prompter": 1}
      }
    },
    {
      "name": "empty_typed_response_fails_parse",
      "agents": {"ask": ["quiet"], "prompter": [""]},
      "expect": {
        "stdout": "quiet\nafter\n",
        "calls": {"ask": 1, "prompter": 1},
        "raises": {"type": "AgentParseError", "fields": {"agent": "prompter", "attempts": 1}}
      }
    }
  ]
}
