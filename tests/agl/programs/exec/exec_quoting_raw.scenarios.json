{
  "scenarios": [
    {
      "name": "spaces_split_only_when_raw",
      "inputs": {"arg": "a b", "k": 4},
      "expect": {
        "stdout": "a b|\na|b|\n4\n"
      }
    },
    {
      "name": "semicolon_runs_second_command_only_when_raw",
      "inputs": {"arg": "x;echo y", "k": -12},
      "expect": {
        "stdout": "x;echo y|\nx|y\n-12\n"
      }
    }
  ]
}
