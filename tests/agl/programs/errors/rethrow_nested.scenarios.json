{
  "scenarios": [
    {
      "name": "inner_raise_is_rethrown_to_outer",
      "params": {"mode": "inner"},
      "expect": {
        "stdout": "inner saw from inner\nouter saw abort\ncontinue\n",
        "raises": {
          "type": "Abort",
          "fields": {"message": "fatal inner"}
        }
      }
    },
    {
      "name": "quiet_inner_body",
      "params": {"mode": "quiet"},
      "expect": {
        "stdout": "inner ok\ncontinue\n",
        "raises": {
          "type": "Abort",
          "fields": {"message": "fatal quiet"}
        }
      }
    }
  ]
}
