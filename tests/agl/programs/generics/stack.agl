# Generics capstone: a generic `record Stack[T]` wrapping `list[T]`, a generic
# `enum Option[T]`, generic functions over them (`peek` returns `Option[T]`,
# `top_or` maps an Option through a default), a generic higher-order `map_top`,
# and `case` destructuring — exercised at `int`, `text`, and a record element
# type. Combines generics + records + enums + lists + HOFs + `case`. A host
# param drives the top-of-stack int so two scenarios exercise the same generic
# body with different runtime values (demonstrating erasure).
record Item
  label: text
  qty: int

record Stack[T]
  items: list[T]
  size: int

enum Option[T]
  | none
  | some(value: T)

def peek[T](s: Stack[T]) -> Option[T] =
  if s.size == 0 => none::[T]() else => some(value = s.items[0])

def map_top[A, B](s: Stack[A], f: A -> B) -> Option[B] =
  case peek(s) of
    | none() => none::[B]()
    | some(value) => some(value = f(value))

param top: int

# Int stack: peek the top — driven by the host param.
let ints: Stack[int] = Stack(items = [top, 20, 30], size = 3)
case peek(ints) of
  | none() => print "ints: empty"
  | some(value) => print "ints top: ${value}"

# Map the int top through a concrete lambda to a text Option.
case map_top(ints, fn(n: int) -> text => "v${n}") of
  | none() => print "mapped: empty"
  | some(value) => print "mapped: ${value}"

# Empty text stack: the nullary branch.
let no_words: list[text] = []
let words: Stack[text] = Stack(items = no_words, size = 0)
case peek(words) of
  | none() => print "words: empty"
  | some(value) => print "words top: ${value}"

# Record-element stack: field access on the destructured payload.
let items: Stack[Item] = Stack(
  items = [Item(label = "bolt", qty = 4), Item(label = "nut", qty = 9)],
  size = 2,
)
case peek(items) of
  | none() => print "items: empty"
  | some(value) => print "item top: ${value.label} x${value.qty}"
