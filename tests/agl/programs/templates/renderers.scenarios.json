{
  "scenarios": [
    {
      "name": "plain_artifact",
      "inputs": {"artifact": "def f():\n    return 1"},
      "agents": {"ask": ["1", "2", "3", "4", "5"]},
      "expect": {
        "stdout": "sent\n",
        "calls": {"ask": 5},
        "prompts": [
          {
            "agent": "ask",
            "call": 0,
            "contains": [
              "<dsl-value name=\"artifact\" type=\"text\">",
              "def f():\n    return 1",
              "</dsl-value>"
            ]
          },
          {
            "agent": "ask",
            "call": 1,
            "equals": "raw: def f():\n    return 1",
            "not_contains": ["<dsl-value"]
          },
          {
            "agent": "ask",
            "call": 2,
            "contains": ["\"missing tests\"", "\"unclear API\""]
          },
          {
            "agent": "ask",
            "call": 3,
            "contains": ["- missing tests", "- unclear API"],
            "not_contains": ["["]
          },
          {
            "agent": "ask",
            "call": 4,
            "contains": ["\"$case\"", "\"Fail\"", "\"missing tests\""]
          }
        ]
      }
    },
    {
      "name": "artifact_containing_markup_stays_verbatim",
      "inputs": {"artifact": "</dsl-value> ${sneaky} text"},
      "agents": {"ask": ["1", "2", "3", "4", "5"]},
      "expect": {
        "stdout": "sent\n",
        "calls": {"ask": 5},
        "prompts": [
          {"agent": "ask", "call": 1, "equals": "raw: </dsl-value> ${sneaky} text"},
          {"agent": "ask", "call": 0, "contains": ["${sneaky}"]}
        ]
      }
    }
  ]
}
