# The compact variant: vars for loop-carried state, indented case for branches.
param spec
enum Review
  | Pass
  | Fail(issues: list[text])
agent impl
agent reviewer
var artifact: text = ask("Implement ${spec}", agent: impl)
var review: Review = Pass
do[5]
  review := ask("Review ${artifact}", agent: reviewer, on_parse_error: Retry(n: 2))
  case review of
    | Fail(issues) =>
        artifact := ask("Fix ${issues} in ${artifact}", agent: impl)
    | Pass => ()
until review is Pass
print artifact
