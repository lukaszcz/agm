# `parse_json(text) -> json` built-in: strict JSON parsing with no target
# schema.  Raises JsonParseError (fields: message, trace_id, raw) on malformed
# input.  Contrasts with `text as json`, which embeds text as a JSON string
# without parsing.
param raw

# `text as json` embeds the text verbatim as a JSON string — always succeeds
let embedded: json = raw as json
print embedded

# parse_json performs strict parsing — may raise JsonParseError
try
  let parsed = parse_json(raw)
  print parsed
catch JsonParseError as e =>
  print "parse error"
  print e.raw
  let has_msg = e.message != ""
  print "has_message: ${has_msg as text}"
  let has_id = e.trace_id != ""
  print "has_trace_id: ${has_id as text}"
