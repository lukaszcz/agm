{
  "scenarios": [
    {
      "name": "dot_unknown_code_and_user",
      "inputs": {"code": 9, "who": "mallory"},
      "agents": {"picker": ["{\"$case\": \"Dot\"}"]},
      "expect": {
        "stdout": "dot\nnested other\nother 9\nuntagged\nunknown\n",
        "calls": {"picker": 1}
      }
    },
    {
      "name": "line_routes_nested_pattern",
      "inputs": {"code": 1, "who": "alice"},
      "agents": {"picker": ["{\"$case\": \"Line\", \"len\": 5}"]},
      "expect": {
        "stdout": "line 5\nnested line 5\none\nuntagged\nknown\n",
        "calls": {"picker": 1}
      }
    },
    {
      "name": "box_multi_field_and_renamed_binding",
      "inputs": {"code": 0, "who": "alice"},
      "agents": {"picker": ["{\"$case\": \"Box\", \"w\": 2, \"h\": 3, \"label\": \"big\"}"]},
      "expect": {
        "stdout": "box 2x3 big\nnested other\nzero\ntagged big\nknown\n",
        "calls": {"picker": 1}
      }
    }
  ]
}
