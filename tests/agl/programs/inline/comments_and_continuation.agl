# Leading full-line comment; comments must not disturb layout, and newlines are
# suppressed inside brackets.
input n: int   # trailing comment on a statement

# comment between statements
let xs = [
  1,
  2,  # comment inside a bracketed continuation
  3,
]
print xs

let total = (
  n +
  1
)
print total

let pairs = {
  one: 1,
  two: 2,
}
print pairs

if n > 0 =>  # trailing comment before an indented suite
  print "pos"  # comment inside a suite
# full-line comment between a branch body and the next branch marker
| else =>
  print "neg"
