# Interpolation: expressions inside ${...}, adjacency, nested braces, structured
# value rendering inside prompts.
record Item
  name: text
  qty: int

enum Pick
  | One(item: Item)
  | Nothing

param who

let item = Item(name: "bolt", qty: 7)
let items = ["alpha", "beta"]
let pick: Pick = One(item: item)

let a = ask "Hello ${who}, qty ${item.qty}, sum ${1 + 2 * 3}."
let b = ask "${who}${item.qty}"
let c = ask "data: ${ {kind: "demo", tags: items} }"
let d = ask """
Report for ${who}:
${item}
${pick}
"""
print a
print b
print c
print d
