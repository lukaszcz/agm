# Lenient JSON recovery (extract from fences/prose, repair trivially malformed
# JSON, then validate strictly) is the portable default; `strict_json: true` is
# a per-call opt-in to strict parsing.
agent counter
agent fetcher
let n: int = ask("Count the items.", agent: counter)
print n
let exact: int = ask("Count again.", agent: counter, strict_json: true)
print exact
let data: json = ask("Fetch the data.", agent: fetcher)
print data
