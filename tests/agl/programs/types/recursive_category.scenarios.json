{
  "scenarios": [
    {
      "name": "with_grandchild",
      "params": {"root_name": "root", "child_name": "child", "include_grandchild": true},
      "expect": {
        "stdout": "3\nroot > child > leaf\n1\nempty\n"
      }
    },
    {
      "name": "without_grandchild",
      "params": {"root_name": "root", "child_name": "child", "include_grandchild": false},
      "expect": {
        "stdout": "2\nroot > child\n1\nempty\n"
      }
    },
    {
      "name": "different_names",
      "params": {"root_name": "electronics", "child_name": "phones", "include_grandchild": true},
      "expect": {
        "stdout": "3\nelectronics > phones > leaf\n1\nempty\n"
      }
    }
  ]
}
