# Renderer selection: boundary-marked default for text, raw / json / bullets
# overrides.
enum Review
  | Fail(issues: list[text])
  | Pass

input artifact

let issues = ["missing tests", "unclear API"]
let review: Review = Fail(issues: issues)

let a = ask "default: ${artifact}"
let b = ask "raw: ${artifact as raw}"
let c = ask "json list: ${issues as json}"
let d = ask "bullets:\n${issues as bullets}"
let e = ask "review: ${review as json}"
print "sent"
