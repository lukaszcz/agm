# Library module imported by programs/modules/generic_library.agl. Exports a
# generic enum, a generic record, and generic functions over them so the entry
# can exercise imported generics, qualified constructors, and pattern matching.
enum Option[T]
  | none
  | some(value: T)

record Pair[A, B]
  first: A
  second: B

def or_else[T](o: Option[T], fallback: T) -> T =
  case o of
    | none() => fallback
    | some(value) => value

def make_pair[A, B](a: A, b: B) -> Pair[A, B] = Pair(first: a, second: b)
