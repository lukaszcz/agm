{
  "scenarios": [
    {
      "name": "list_exhausted_before_bound",
      "params": {"items": [1, 2, 3], "n": 10},
      "expect": {"stdout": "6\n"}
    },
    {
      "name": "bound_exhausted_before_list",
      "params": {"items": [1, 2, 3, 4, 5], "n": 2},
      "expect": {
        "raises": {"type": "MaxIterationsExceeded", "fields": {"limit": 2}}
      }
    },
    {
      "name": "zero_bound_no_iterations",
      "params": {"items": [1, 2], "n": 0},
      "expect": {"stdout": "0\n"}
    },
    {
      "name": "bound_equals_list_length_normal_completion",
      "params": {"items": [1, 2, 3], "n": 3},
      "expect": {"stdout": "6\n"}
    }
  ]
}
