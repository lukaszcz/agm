{
  "scenarios": [
    {
      "name": "small_int_input",
      "inputs": {"n": 9},
      "expect": {
        "stdout_contains": [
          "plain text line\n",
          "two\nlines\n",
          "42\n",
          "-7\n",
          "2.5\n",
          "true\n",
          "false\n",
          "9\n",
          "\"a\"",
          "\"b\"",
          "\"alpha\"",
          "\"beta\"",
          "\"name\"",
          "\"x\"",
          "\"score\"",
          "\"$case\"",
          "\"Bad\"",
          "\"slow\"",
          "null\n"
        ],
        "stdout_not_contains": ["<dsl-value", "True", "False"]
      }
    },
    {
      "name": "arbitrary_precision_int_input",
      "inputs": {"n": 123456789012345678901234567890},
      "expect": {
        "stdout_contains": ["123456789012345678901234567890\n"],
        "stdout_not_contains": ["<dsl-value", "e+", "E+"]
      }
    }
  ]
}
