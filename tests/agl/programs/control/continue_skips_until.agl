# Demonstrates that `continue` skips the `until` condition.
# When i = n, continue fires — even though the `until` predicate (i >= n)
# would be true at that moment — and the until check is skipped, so the loop
# restarts without exiting.  The loop can only exit via until when i > n,
# i.e. on the iteration where i = n + 1.
param n: int
var i: int = 0
do[n + 2]
  i := i + 1
  if i == n => continue
until i >= n
print i
