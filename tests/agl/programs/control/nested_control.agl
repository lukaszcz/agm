# Deeply nested control flow: loop > case > case > if, dedent-routed branch
# markers, state threading through outer vars.
enum Review
  | Pass
  | Fail(issues: list[text])

enum Plan
  | Retry
  | GiveUp(why: text)

param spec

agent impl
agent reviewer
agent planner

var artifact: text = ask("Implement ${spec}", agent: impl)
var status: text = "working"

do[3]
  let review: Review = ask("Review:\n${artifact}", agent: reviewer)
  case review of
    | Pass() =>
        status := "accepted"
    | Fail(issues) =>
        let plan: Plan = ask("Plan for:\n${issues}", agent: planner)
        case plan of
          | Retry() =>
              artifact := ask("Fix ${issues} in ${artifact}", agent: impl)
          | GiveUp(why) =>
              if why = "hopeless" =>
                status := "abandoned"
              else =>
                status := "deferred: ${why}"
until status != "working"
print status
print artifact
