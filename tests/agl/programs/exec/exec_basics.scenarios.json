{
  "scenarios": [
    {
      "name": "simple_name",
      "inputs": {"name": "world"},
      "expect": {
        "stdout_contains": [
          "hi world\n",
          "padded\nend marker\n",
          "43\n",
          "\"k\"",
          "\"a\"",
          "\"b\""
        ]
      }
    },
    {
      "name": "name_with_underscore",
      "inputs": {"name": "hello_world"},
      "expect": {
        "stdout_contains": ["hi hello_world\n", "padded\nend marker\n", "43\n"]
      }
    }
  ]
}
