{
  "network": {
    "allowedDomains": [
      "claude.com",
      "platform.claude.com",
      "api.anthropic.com",
      "pypi.org",
      "files.pythonhosted.org",
      "registry.npmjs.org",
      "github.com",
      "api.github.com",
      "gist.github.com",
      "uploads.github.com",
      "release-assets.githubusercontent.com",
      "raw.githubusercontent.com",
      "gitlab.com",
      "bitbucket.org"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "~/.claude"
    ],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
