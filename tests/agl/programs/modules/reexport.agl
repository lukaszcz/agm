# Re-export: verify that modules can re-export names with export declarations.
# math.facade re-exports everything from math.ops.
# math.selective re-exports only `add` from math.ops.
# math.renamed re-exports `add as plus` from math.ops.
# types.public re-exports a record type and its constructor from types.geo.
open import math/facade
import math/selective as sel
import math/renamed as ren
import math/masked as masked
import math/tools_facade as tools
import chain/top as chain
open import types/public
# math.facade re-exports add and mul from math.ops.
print(add(3, 4) as text)
print(mul(2, 5) as text)

# math.selective re-exports add but NOT mul; access via qualifier.
print(sel::add(10, 1) as text)

# math.renamed re-exports add as plus; access via qualifier.
print(ren::plus(6, 2) as text)

# math.masked re-exports add but hides mul.
print(masked::add(20, 1) as text)

# math.tools_facade wildcard re-exports every module under math.tools.
print(tools::inc(4) as text)
print(tools::dec(4) as text)

# chain.top receives answer through a multi-hop re-export chain.
print(chain::answer() as text)

# types.public re-exports the Point type and make_point.
let p = make_point(7, 3)
print(p.x as text)
print(p.y as text)
