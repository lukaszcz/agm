{
  "scenarios": [
    {
      "name": "positive_values",
      "params": {"x": 3, "y": 4},
      "expect": {
        "stdout": "8\n7\n"
      }
    },
    {
      "name": "zero_values",
      "params": {"x": 0, "y": 0},
      "expect": {
        "stdout": "1\n0\n"
      }
    },
    {
      "name": "negative_value",
      "params": {"x": -2, "y": 5},
      "expect": {
        "stdout": "4\n3\n"
      }
    }
  ]
}
