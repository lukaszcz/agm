# Generics: a generic `record Box[T]`. Exercises construction with inference and
# with an explicit `Box::[…]` override, field access, nesting (`Box[Box[int]]`),
# and erasure — the SAME generic mechanism builds `Box[int]` and `Box[text]`
# from one definition at runtime. The generic constructor is bound as a
# first-class value (annotated `(int) -> Box[int]`) and then passed THROUGH a
# generic higher-order function and called there, building `Box[int]` at runtime
# under type erasure.
def apply[A, B](x: A, f: (A) -> B) -> B = f(x)

record Box[T]
  value: T

# Inference from the payload, then field access.
let bi: Box[int] = Box(value: 5)
print bi.value

# Same definition, a different instantiation — erasure means one runtime path.
let bt: Box[text] = Box(value: "hi")
print bt.value

# Explicit type-argument override.
let be = Box::[int](value: 99)
print be.value

# Nesting: a Box of a Box.
let nested: Box[Box[int]] = Box(value: Box(value: 7))
print nested.value.value

# The generic constructor as a first-class value, passed THROUGH a generic HOF
# and called there — `apply` builds `Box(value: 42)` at runtime via erasure.
let mk: (int) -> Box[int] = Box
let made = apply(42, mk)
print made.value
