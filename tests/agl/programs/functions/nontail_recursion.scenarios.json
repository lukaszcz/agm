{
  "scenarios": [
    {
      "name": "non_tail_recursion_error_is_catchable",
      "params": {"depth": 100000, "catch_it": true},
      "runtime": {"default_call_depth_limit": 400},
      "expect": {"stdout": "400\n"}
    },
    {
      "name": "non_tail_recursion_error_when_uncaught",
      "params": {"depth": 100000, "catch_it": false},
      "runtime": {"default_call_depth_limit": 400},
      "expect": {
        "stdout": "",
        "raises": {"type": "RecursionError", "fields": {"limit": 400}}
      }
    }
  ]
}
