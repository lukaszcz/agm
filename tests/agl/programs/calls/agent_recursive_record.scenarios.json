{
  "scenarios": [
    {
      "name": "flat_no_subcategories",
      "agents": {
        "tree_source": ["{\"name\": \"Root\", \"subcategories\": []}"]
      },
      "expect": {
        "stdout": "Root\n1\n",
        "calls": {"tree_source": 1}
      }
    },
    {
      "name": "nested_two_levels",
      "agents": {
        "tree_source": [
          "{\"name\": \"Root\", \"subcategories\": [{\"name\": \"Child\", \"subcategories\": [{\"name\": \"Grandchild\", \"subcategories\": []}]}]}"
        ]
      },
      "expect": {
        "stdout": "Root\n3\n",
        "calls": {"tree_source": 1}
      }
    },
    {
      "name": "abort_on_missing_nested_field",
      "agents": {
        "tree_source": [
          "{\"name\": \"Root\", \"subcategories\": [{\"subcategories\": []}]}"
        ]
      },
      "expect": {
        "calls": {"tree_source": 1},
        "raises": {
          "type": "AgentParseError",
          "fields": {"agent": "tree_source", "attempts": 1, "target_type": "Category"}
        }
      }
    }
  ]
}
