# The compact one-line variant, with the declarations it assumes.
param spec
enum Review
  | Pass
  | Fail(issues: list[text])
agent impl
agent reviewer
var artifact: text = impl "Implement ${spec}"; do[5] let review: Review = reviewer[on_parse_error: retry[2]] "Review ${artifact}"; case review of | Pass => pass | Fail(issues) => set artifact = impl "Fix ${issues} in ${artifact}" until review is Pass
print artifact
