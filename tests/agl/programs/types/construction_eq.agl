# Record/enum construction with '=' named args, bare-name shorthand (R(x) means
# R(x = x)), reordered fields, and nested construction. Field declarations keep
# ':'. Constructed values are verified by field access and pattern destructuring
# (scalar prints only, no whole-value rendering).
record R
  x: int
  y: int

enum E
  | A(x: int)
  | B(x: int, r: R)

param base: int

# Explicit '=' construction.
let r1 = R(x = base, y = base + 1)
print r1.x
print r1.y

# Reordered named fields.
let r2 = R(y = 20, x = 10)
print r2.x
print r2.y

# Shorthand: bare 'x' means 'x = x'.
let x = 7
let r3 = R(x, y = x + 1)
print r3.x
print r3.y

# Enum construction with '=' and nested construction using shorthand.
let e1 = A(x = base)
let e2 = B(x, r = R(x = x + 1, y = x + 2))

case e1 of
  | A(x) => print x
  | B(x, r) => print "unreachable"

case e2 of
  | A(x) => print "unreachable"
  | B(x, r) =>
      print x
      print r.x
      print r.y
