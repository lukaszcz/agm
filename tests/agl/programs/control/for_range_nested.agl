# Nested range fors: outer range + inner range, range inside collection for,
# and outer range containing an inner collection for.
# Exercises: range-in-range, collection-for with inner range, range-for with inner collection-for.
param rows: int
param cols: int
param scale_items: list[int] = [10, 20]

var grid_sum: int = 0
for r in 1 to rows do
  for c in 1 to cols do
    grid_sum := grid_sum + r + c
  done
done
print grid_sum

var items: list[int] = [1, 2, 3]
var mixed: int = 0
for x in items do
  for j in 1 to cols do
    mixed := mixed + x + j
  done
done
print mixed

var cross: int = 0
for i in 1 to rows do
  for x in scale_items do
    cross := cross + i * x
  done
done
print cross
