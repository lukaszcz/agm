# Lexical scoping: branch shadowing, set across scopes, do-loop iteration scope.
param mode

let x = 1
var trail: text = ""

if
  | mode = "shadow" =>
    let x = 2
    set trail = "branch ${x}"
  | mode = "plain" =>
    set trail = "branch kept ${x}"
  | else =>
    ()

print trail
print "after ${x}"

var counter: int = 0
do[5]
  let bump = counter + 1
  set counter = bump
until counter >= 3
print counter
