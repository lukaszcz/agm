# Bare constructors as function values with explicit type arguments.
# `some::[int]` is a function value equivalent to `fn (x: int) => some(x)`;
# `none::[int]` constructs the nullary value directly, with no parentheses.
# The qualified `Option.some::[int]` / `Option.none::[int]` forms behave the same.
enum Option[T]
  | none
  | some(value: T)

# A payload constructor pinned with `::[int]` is a positional function value.
let mk: (int) -> Option[int] = some::[int]
let v = mk(7)

# A nullary constructor pinned with `::[int]` constructs directly.
let z: Option[int] = none::[int]

# The qualified forms work the same way.
let qmk: (int) -> Option[int] = Option.some::[int]
let qv = qmk(9)
let qz: Option[int] = Option.none::[int]

print(v is Option.some)
print(z is Option.none)
print(qv is Option.some)
print(qz is Option.none)
