{
  "scenarios": [
    {
      "name": "accepted_first_round",
      "params": {"spec": "a widget"},
      "agents": {
        "impl": ["v1"],
        "reviewer": ["{\"$case\": \"Pass\"}"],
        "planner": []
      },
      "expect": {
        "stdout": "accepted\nv1\n",
        "calls": {"impl": 1, "reviewer": 1, "planner": 0}
      }
    },
    {
      "name": "two_retry_rounds_then_accepted",
      "params": {"spec": "a widget"},
      "agents": {
        "impl": ["v1", "v2", "v3"],
        "reviewer": [
          "{\"$case\": \"Fail\", \"issues\": [\"i1\"]}",
          "{\"$case\": \"Fail\", \"issues\": [\"i2\"]}",
          "{\"$case\": \"Pass\"}"
        ],
        "planner": ["{\"$case\": \"Retry\"}", "{\"$case\": \"Retry\"}"]
      },
      "expect": {
        "stdout": "accepted\nv3\n",
        "calls": {"impl": 3, "reviewer": 3, "planner": 2},
        "prompts": [
          {"agent": "planner", "call": 1, "contains": ["i2"]},
          {"agent": "impl", "call": 2, "contains": ["v2"]}
        ]
      }
    },
    {
      "name": "hopeless_giveup",
      "params": {"spec": "a widget"},
      "agents": {
        "impl": ["v1"],
        "reviewer": ["{\"$case\": \"Fail\", \"issues\": [\"broken\"]}"],
        "planner": ["{\"$case\": \"GiveUp\", \"why\": \"hopeless\"}"]
      },
      "expect": {
        "stdout": "abandoned\nv1\n",
        "calls": {"impl": 1, "reviewer": 1, "planner": 1}
      }
    },
    {
      "name": "deferred_giveup",
      "params": {"spec": "a widget"},
      "agents": {
        "impl": ["v1"],
        "reviewer": ["{\"$case\": \"Fail\", \"issues\": [\"broken\"]}"],
        "planner": ["{\"$case\": \"GiveUp\", \"why\": \"needs design input\"}"]
      },
      "expect": {
        "stdout": "deferred: needs design input\nv1\n",
        "calls": {"impl": 1, "reviewer": 1, "planner": 1}
      }
    },
    {
      "name": "endless_retries_exhaust_loop",
      "params": {"spec": "a widget"},
      "agents": {
        "impl": {"responses": ["v1", "fix"], "repeat_last": true},
        "reviewer": {
          "responses": ["{\"$case\": \"Fail\", \"issues\": [\"i\"]}"],
          "repeat_last": true
        },
        "planner": {"responses": ["{\"$case\": \"Retry\"}"], "repeat_last": true}
      },
      "expect": {
        "stdout": "",
        "calls": {"reviewer": 3, "planner": 3, "impl": 4},
        "raises": {"type": "MaxIterationsExceeded", "fields": {"limit": 3}}
      }
    }
  ]
}
