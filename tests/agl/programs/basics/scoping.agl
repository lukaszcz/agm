# Lexical scoping: branch shadowing, set across scopes, do-loop iteration scope.
param mode

let x = 1
var trail: text = ""

if
  | mode == "shadow" =>
    let x = 2
    trail := "branch ${x}"
  | mode == "plain" =>
    trail := "branch kept ${x}"
  | else =>
    ()

print trail
print "after ${x}"

var counter: int = 0
do[5]
  let bump = counter + 1
  counter := bump
until counter >= 3
print counter
