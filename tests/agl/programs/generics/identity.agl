# Generics: a polymorphic identity `def` applied at several instantiations
# (int, text, list, record), an explicit `id::[…]` type-argument override, and
# the generic `def` bound as a first-class value through an expected function
# type and then applied. Also exercises a `let` annotation inside a generic
# def body that references the def's type variable to build a `list[T]`
# (`singleton`), instantiated at int and text. Also exercises a parameterized
# type alias (`Seq[A]`) instantiated at a concrete element type. A host param
# drives the int passed to `id` so two scenarios prove the same generic body
# serves different runtime values (erasure).
def id[T](x: T) -> T = x

# A generic def whose body uses a `let` annotation referencing the def's own
# type variable `T` to build a `list[T]`.
def singleton[T](x: T) -> list[T] =
  let single: list[T] = [x]
  single

# A parameterized type alias: `Seq[A]` abbreviates `list[A]`.
type Seq[A] = list[A]

record Tag
  name: text
  weight: int

param val: int

# Inferred instantiations from the argument type.
print(id(val))
print(id("hi"))

let xs = id([1, 2, 3])
print(xs[0])

let t = id(Tag(name = "core", weight = 7))
print(t.name)
print(t.weight)

# Explicit type-argument override at the call site.
print(id::[int](9))

# Generic `def` as a first-class value: the expected type instantiates `T`.
let f: (text) -> text = id
print(f("via value"))

# The type-variable `let` annotation in action, instantiated at int and text.
let ys = singleton(11)
print ys[0]
let zs = singleton("solo")
print zs[0]

# A value annotated with the parameterized alias instantiated at `text`.
let names: Seq[text] = ["alpha", "beta"]
print names[1]
