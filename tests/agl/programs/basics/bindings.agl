# let/var/set, literal inference, agent-call targets, bare expression statements.
param start

agent impl

let greeting = "hello"
let count = 2
let exact = 1.5
let okay = true

var artifact = impl "Start from ${start}"
print artifact
set artifact = impl "Refine: ${artifact}"
print artifact

var total: int = count + 1
set total = total * 2
print total

ask "Note ${greeting} ${exact} ${okay}"
print "done"
