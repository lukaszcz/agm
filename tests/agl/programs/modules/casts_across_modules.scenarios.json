{
  "scenarios": [
    {
      "name": "all_valid",
      "module_roots": ["program_modules/modules/casts_across_modules"],
      "params": {"amount": "42", "point_json": "{\"x\": 1, \"y\": 2}"},
      "agents": {"source": ["{\"x\": 7, \"y\": 8}"]},
      "expect": {
        "stdout": "42\npoint 1,2\nagent point 7,8\n",
        "calls": {"source": 1}
      }
    },
    {
      "name": "fallback_and_schema_errors",
      "module_roots": ["program_modules/modules/casts_across_modules"],
      "params": {"amount": "oops", "point_json": "{\"x\": 1}"},
      "agents": {"source": ["{\"x\": 1}"]},
      "expect": {
        "stdout": "-1\nbad point: json -> parsing::Point\nagent bad point: parsing::Point\n",
        "calls": {"source": 1}
      }
    },
    {
      "name": "malformed_json_caught",
      "module_roots": ["program_modules/modules/casts_across_modules"],
      "params": {"amount": "100", "point_json": "not json"},
      "agents": {"source": ["{\"x\": 3, \"y\": 4}"]},
      "expect": {
        "stdout": "100\nbad json: not json\nagent point 3,4\n",
        "calls": {"source": 1}
      }
    }
  ]
}
