# `decimal as int` (D4): succeeds only when the decimal has no fractional part;
# raises CastError otherwise.  The CastError carries source_type="decimal",
# target_type="int", and raw=the original decimal value.
param d: decimal

try
  let i = d as int
  print "ok: ${i}"
  print "next: ${i + 1}"
catch CastError as e =>
  print "not integral: ${e.raw}"
  print e.source_type
  print e.target_type
