# Bounds and step are evaluated exactly once at loop entry.
# Mutating the vars they reference from inside the body does not change iteration count.
# Exercises: single-evaluation of bounds and step at loop entry, ascending and descending.
param down_start: int = 10
param down_stop: int = 5
param down_step: int = 2

var end_val: int = 5
var step_val: int = 1
var count: int = 0

for i in 1 to end_val by step_val do
  count := count + 1
  end_val := end_val + 100
  step_val := step_val + 100
done
print count
print end_val

var stop_var: int = down_stop
var step_var: int = down_step
var count2: int = 0
for i in down_start downto stop_var by step_var do
  count2 := count2 + 1
  step_var := step_var + 100
done
print count2
