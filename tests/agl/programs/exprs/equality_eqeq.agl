# Equality '==' and inequality '!=' both produce bool, across scalar and
# structured values (int, decimal, text, list, dict, record, enum). Ordering
# operators (<, <=, >, >=) compare ints and text lexicographically. Record/enum
# construction uses '='; dict literals keep ':'.
record P
  n: int

enum E
  | A
  | B(t: text)

param x: int
param y: decimal
param word: text

print(x == 3)
print(x != 3)
print(x == y)
print(word == "kiwi")
print(word != "kiwi")
print([1, 2] == [1, 2])
print([1, 2] != [1, 3])
print({a: 1} == {a: 1})
print(true != false)
print(P(n = 1) == P(n = 1))
print(P(n = 1) != P(n = 2))
print(E.A == E.A)
print(E.B(t = "x") == E.B(t = "y"))
print(x < 4)
print(x <= 3)
print(x > 2)
print(x >= 4)
print(word < "mango")
let same = (x == 3)
print same
