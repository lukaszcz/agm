# Triple-quoted templates: dedent rule (drop one leading/trailing newline, strip
# minimum common indentation), interpolation holes are never dedented.
param body

agent critic

if true =>
  let block = ask("""
  Header line:
    keep two spaces
  A "quoted" tail.
  """, agent = critic)
  print "block sent"
else =>
  ()

let mixed = ask("""
Wrap:
${body}
End.
""", agent = critic)
print "mixed sent"
