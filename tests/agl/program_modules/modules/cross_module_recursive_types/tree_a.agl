# Library module forming a cross-module type cycle with tree_b: NodeA's
# BranchA variant carries a NodeB (defined in tree_b), and tree_b's NodeB
# carries a list[NodeA] back. Cross-module cycles are legal the same way
# same-module mutual recursion is.
open import tree_b
enum NodeA
  | LeafA
  | BranchA(value: int, child: NodeB)
