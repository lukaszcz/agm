{
  "scenarios": [
    {
      "name": "plain_name",
      "inputs": {"who": "Ada"},
      "agents": {"ask": ["r1", "r2", "r3", "r4"]},
      "expect": {
        "stdout": "r1\nr2\nr3\nr4\n",
        "calls": {"ask": 4},
        "prompts": [
          {"agent": "ask", "call": 0, "contains": ["Ada", "qty 7,", "sum 7."]},
          {"agent": "ask", "call": 1, "contains": ["Ada"]},
          {
            "agent": "ask",
            "call": 2,
            "contains": ["data: ", "\"kind\"", "\"demo\"", "\"tags\"", "\"alpha\"", "\"beta\""]
          },
          {
            "agent": "ask",
            "call": 3,
            "contains": [
              "Report for ",
              "Ada",
              "\"name\"",
              "\"bolt\"",
              "\"qty\"",
              "\"$case\"",
              "\"One\""
            ]
          }
        ]
      }
    },
    {
      "name": "name_with_template_syntax_is_not_reinterpolated",
      "inputs": {"who": "Eve ${exploit} \"quoted\""},
      "agents": {"ask": ["w", "x", "y", "z"]},
      "expect": {
        "stdout": "w\nx\ny\nz\n",
        "calls": {"ask": 4},
        "prompts": [
          {
            "agent": "ask",
            "call": 0,
            "contains": ["Eve ${exploit} \"quoted\"", "qty 7,", "sum 7."]
          }
        ]
      }
    }
  ]
}
