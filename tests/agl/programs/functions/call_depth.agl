# Recursion that stays within the configured call-depth limit returns normally;
# recursion that exceeds it raises RecursionError. The limit is host-configured
# (--max-call-depth / [exec] max-call-depth, or the runtime default).
param n: int

def countdown(x: int) =
  if x <= 0 => 0 else => countdown(x - 1)

print(countdown(n))
