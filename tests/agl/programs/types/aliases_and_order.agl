# Type aliases are transparent; type declarations are collected
# program-wide, so they may appear after their first use.
input verdict: Status

agent judge

let initial: Status = verdict

if initial is Status.Approved => print "approved input"
| else => print "not approved"

let next: Status = judge "Re-judge it."

case next of
  | Approved => print "ok"
  | Rejected(notes) => print "notes:\n${notes}"

type Status = Verdict

enum Verdict
  | Approved
  | Rejected(notes: list[text])
