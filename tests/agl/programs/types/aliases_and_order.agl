# Type aliases are transparent; type declarations are collected
# program-wide, so they may appear after their first use.
param verdict: Status

agent judge

let initial: Status = verdict

if initial is Status::Approved => print "approved input" else => print "not approved"

let next: Status = ask("Re-judge it.", agent = judge)

case next of
  | Approved() => print "ok"
  | Rejected(notes) => print "notes:\n${notes}"

type Status = Verdict

enum Verdict
  | Approved
  | Rejected(notes: list[text])
