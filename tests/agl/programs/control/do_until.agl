# do[N]...until: post-test, loop-carried state through outer vars, iteration
# bindings visible to the condition, MaxIterationsExceeded on exhaustion.
param target: int

agent oracle

var hits: int = 0
var rounds: int = 0

do[4]
  rounds := rounds + 1
  let verdict = ask("Round ${rounds}: have ${hits} of ${target}.", agent = oracle)
  if verdict == "hit" =>
    hits := hits + 1
  else =>
    ()
until hits >= target
print rounds
print hits
