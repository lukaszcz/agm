{
  "scenarios": [
    {
      "name": "all_failure_paths",
      "inputs": {"d": 0, "mode": "diverge"},
      "agents": {"tosser": ["{\"$case\": \"Tails\"}"]},
      "expect": {
        "stdout_contains": [
          "math failed: ",
          "no match for Coin\n",
          "exhausted at 2\n",
          "end\n"
        ],
        "stdout_not_contains": ["heads", "loop done", "generic:", "anon"],
        "calls": {"tosser": 1}
      }
    },
    {
      "name": "all_success_paths",
      "inputs": {"d": 5, "mode": "converge"},
      "agents": {"tosser": ["{\"$case\": \"Heads\"}"]},
      "expect": {
        "stdout": "2\nheads\nloop done 1\nend\n",
        "calls": {"tosser": 1}
      }
    },
    {
      "name": "abort_caught_by_exception_base",
      "inputs": {"d": 5, "mode": "boom"},
      "agents": {"tosser": ["{\"$case\": \"Heads\"}"]},
      "expect": {
        "stdout_contains": ["generic: boom\n", "anon\n", "exhausted at 2\n", "end\n"],
        "calls": {"tosser": 1}
      }
    }
  ]
}
