# First-class function values: binding a def to a typed let, passing a function
# as an argument, lambdas with explicit and inferred return types.

def classify(n: int) -> text =
  if n > 0 => "pos" | n < 0 => "neg" | else => "zero"

def label(n: int) -> text =
  "val=" + classify(n)

# Higher-order: accept a function value and apply it.
def apply(f: (int) -> text, n: int) -> text = f(n)

# Bind a named def to a typed let (first-class function value).
let g: (int) -> text = classify

# Lambda with explicit return type.
let dbl = fn(x: int) -> int => x * 2

# Lambda with inferred return type.
let inc = fn(x: int) => x + 1

print(g(7))
print(g(-3))
print(g(0))
print(dbl(4))
print(inc(9))
print(apply(classify, 10))
print(apply(label, -5))
