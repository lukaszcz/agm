# exec: shell commands as call-shaped expressions; trailing-newline stripping;
# typed targets parsed like agent output.
input name

let greeting: text = exec "printf 'hi %s' ${name}"
print greeting

let trimmed: text = exec "echo padded"
print trimmed
print "end marker"

exec "true"

let answer: int = exec "echo 42"
print(answer + 1)

let data: json = exec "printf '{\"k\": [1, 2]}'"
print data

let words: list[text] = exec "printf '[\"a\", \"b\"]'"
print words
