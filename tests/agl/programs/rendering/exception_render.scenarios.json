{
  "scenarios": [
    {
      "name": "bad_input_triggers_cast_error",
      "params": {"bad_input": "abc"},
      "expect": {
        "stdout_contains": [
          "CastError(message = \"Failed to parse text as JSON:",
          "source_type = \"text\", target_type = \"int\", raw = \"abc\")",
          "caught: text -> int\n",
          "\"source_type\": \"text\"",
          "\"target_type\": \"int\"",
          "\"raw\": \"abc\"",
          "no int\n",
          "ArithmeticError(message = \"Division by zero\", trace_id = \"",
          "operation = \"/\")",
          "operation: /\n"
        ],
        "stdout_not_contains": ["parsed:"]
      }
    },
    {
      "name": "valid_input_no_cast_error",
      "params": {"bad_input": "42"},
      "expect": {
        "stdout_contains": [
          "parsed: 42\n",
          "got int\n",
          "ArithmeticError(message = \"Division by zero\", trace_id = \"",
          "operation = \"/\")",
          "operation: /\n"
        ],
        "stdout_not_contains": ["CastError", "caught:"]
      }
    }
  ]
}
