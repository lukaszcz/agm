{
  "scenarios": [
    {
      "name": "nested_2x3",
      "params": {"rows": 2, "cols": 3},
      "expect": {"stdout": "21\n36\n90\n"}
    },
    {
      "name": "nested_1x1",
      "params": {"rows": 1, "cols": 1},
      "expect": {"stdout": "2\n9\n30\n"}
    },
    {
      "name": "nested_degenerate_rows_zero",
      "params": {"rows": 0, "cols": 3},
      "expect": {"stdout": "0\n36\n0\n"}
    },
    {
      "name": "range_outer_collection_inner_custom_items",
      "params": {"rows": 3, "cols": 2, "scale_items": [1, 2, 3]},
      "expect": {"stdout": "21\n21\n36\n"}
    }
  ]
}
