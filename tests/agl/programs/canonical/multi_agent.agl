# The multi-agent refinement loop, finished with exec and print.
enum Review
  | Pass
  | Fail(issues: list[text])

input spec

agent impl
agent reviewer
agent critic

var artifact: text = ask("Implement ${spec}", agent: impl)

# code and design declared as vars outside the loop so the until condition can see them.
var code: Review = Pass
var design: Review = Pass

do[5]
  set code = ask("Review correctness:\n${artifact}", agent: reviewer, on_parse_error: Retry(n: 2))
  set design = ask("Review design:\n${artifact}", agent: critic, on_parse_error: Retry(n: 2))

  if code is Fail or design is Fail =>
    set artifact = ask("""
    Fix valid issues.

    Correctness review:
    ${code}

    Design review:
    ${design}

    Current artifact:
    ${artifact}
    """, agent: impl)
  | else =>
    ()
until code is Pass and design is Pass

let stamp: text = exec "printf 'final:%s' ${artifact}"
print stamp
