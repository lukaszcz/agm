{
  "scenarios": [
    {
      "name": "everything_present",
      "inputs": {"needle": "alpha", "numbers": [1, 2, 3], "k": 2},
      "expect": {
        "stdout": "true\ntrue\ntrue\ntrue\nfalse\ntrue\ntrue\ntrue\n"
      }
    },
    {
      "name": "nothing_present",
      "inputs": {"needle": "delta", "numbers": [], "k": 99},
      "expect": {
        "stdout": "false\nfalse\nfalse\nfalse\ntrue\nfalse\nfalse\ntrue\n"
      }
    },
    {
      "name": "substring_but_not_element",
      "inputs": {"needle": "bet", "numbers": [7], "k": 7},
      "expect": {
        "stdout": "false\ntrue\nfalse\ntrue\ntrue\nfalse\ntrue\ntrue\n"
      }
    }
  ]
}
