# Exception rendering: exceptions render record-style (all fields including
# trace_id) via print, template interpolation, and "as json".
# Combined with try/catch, casts, and conditional logic.
param bad_input: text

# --- print: CastError renders in declaration-order record form ---
try
  let n = bad_input as int
  print "parsed: ${n}"
catch CastError as e =>
  # Print the exception value directly: record-style with all fields.
  print e
  # Interpolate into a template: same AgL form (top-level text is verbatim,
  # but the exception is a nominal value so it renders record-style).
  print "caught: ${e.source_type} -> ${e.target_type}"
  # as json: pretty-prints the exception as a JSON object with all fields.
  print(e as json)

# --- as? cast: check convertibility without exception ---
if bad_input as? int =>
  print "got int"
else =>
  print "no int"

# --- ArithmeticError rendered via print ---
try
  let q = 1 / 0
  print q
catch ArithmeticError as e =>
  print e
  print "operation: ${e.operation}"
