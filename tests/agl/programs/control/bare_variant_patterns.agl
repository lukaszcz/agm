# Bare nullary-variant patterns: a bare name that names an in-scope constructor
# is a constructor pattern (a nullary variant), not a variable binder.  A bare
# name that is NOT a constructor stays an ordinary catch-all binder.
param n: int = 0

enum Color
  | Red
  | Green
  | Blue

enum Box
  | Empty
  | Full(item: int)

enum Wrapper
  | Wrap(color: Color)

# 'Halt' is a variant of both Signal and Trend.  A bare pattern is resolved
# against the scrutinee's enum, so the shared spelling needs no qualification.
enum Signal
  | Halt
  | Go

enum Trend
  | Halt
  | Fall

def name(c: Color) -> text =
  case c of
    | Red => "red"
    | Green => "green"
    | Blue => "blue"

def pick(k: int) -> Color =
  case k of
    | 0 => Red
    | 1 => Green
    | _ => Blue

def code(c: Color) -> int =
  case c of
    | Red => 1
    | rest => 0

def describe(b: Box) -> text =
  case b of
    | Empty => "empty"
    | Full(item) => "full:${item}"

def signal_name(s: Signal) -> text =
  case s of
    | Halt => "stop"
    | Go => "go"

def trend_name(t: Trend) -> text =
  case t of
    | Halt => "flat"
    | Fall => "down"

# Nested: a bare variant pattern (Red) and a bare binder (other) on a subfield.
def inner_name(w: Wrapper) -> text =
  case w of
    | Wrap(color = Red) => "wrapped-red"
    | Wrap(color = other) => "wrapped-${name(other)}"

let c: Color = pick(n)
print(name(c))
print(code(c))
print(describe(Empty))
print(describe(Full(item = n)))
print(inner_name(Wrap(color = c)))
print(signal_name(Signal::Halt))
print(trend_name(Trend::Halt))
