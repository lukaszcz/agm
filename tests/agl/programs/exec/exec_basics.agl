# exec: shell commands as call-shaped expressions; trailing-newline stripping;
# typed targets parsed like agent output (design §4.12, §11.13).
input name

let greeting = exec "printf 'hi %s' ${name}"
print greeting

let trimmed = exec "echo padded"
print trimmed
print "end marker"

exec "true"

let answer: int = exec "echo 42"
print answer + 1

let data: json = exec "printf '{\"k\": [1, 2]}'"
print data

let words: list[text] = exec "printf '[\"a\", \"b\"]'"
print words
