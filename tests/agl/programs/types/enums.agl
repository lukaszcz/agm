# Enums: nullary/single/multi-field variants, qualified and unqualified constructors,
# is / is not, case destructuring.
enum Outcome
  | Done
  | Partial(left: int)
  | Failed(reason: text, fatal: bool)

param fallback

agent worker

let first: Outcome = ask("Attempt the task.", agent: worker)

if
  | first is Done => print "done"
  | first is not Failed => print "not failed"
  | else => print "failed"

case first of
  | Done => print "no work left"
  | Partial(left) => print "remaining ${left}"
  | Failed(reason, fatal) =>
      if fatal => print "fatal: ${reason}"
      else => print "retry later: ${reason}"

let made: Outcome = Partial(left: 2)
print made
let qualified = Outcome.Failed(reason: fallback, fatal: false)
print qualified
