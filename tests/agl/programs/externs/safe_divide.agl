# `try`/`catch ExternError` around a companion that raises on bad input; the
# handler inspects the exception's `function`/`python_type` fields.
extern def divide(a: int, b: int) -> int

param a: int
param b: int

let result = try
  divide(a, b)
catch ExternError as e =>
  print e.function
  print e.python_type
  -1
print result
