# The dialogue loop: typed mutable state driven by two agents.
enum Turn
  | Continue(message: text)
  | Done(answer: text)

param problem

agent researcher
agent critic

var proposal: Turn = ask("Propose a solution for ${problem}.", agent: researcher, on_parse_error: Retry(n: 2))
var final_answer: text = ""

do[6]
  case proposal of
    | Continue(message) =>
        let critique: Turn = ask("Critique this proposal:\n${message}", agent: critic, on_parse_error: Retry(n: 2))
        set proposal = ask("Revise using critique:\n${critique}", agent: researcher, on_parse_error: Retry(n: 2))

    | _ => ()

until proposal is Done

case proposal of
  | Done(answer) =>
      set final_answer = answer
  | _ => ()

print final_answer
