# Imported generics: open and module-qualified applied types in annotations,
# function signatures, nested applications, constructor calls, qualified enum
# constructors with explicit type arguments, and generic pattern matching.
import library

def unbox(box: Box[int]) -> int = box.value

def describe_option(option: library::Option[int]) -> text =
  case option of
    | none() => "none"
    | some(value) => "some ${value}"

param seed: int

let open_box: Box[int] = Box(value = seed)
let qualified_box: library::Box[int] = library::Box(value = 7)
let nested: library::Box[Box[int]] = library::Box(value = open_box)

print(unbox(open_box))
print(qualified_box.value)
print(nested.value.value)

let some_value = library::Option[int]::some(value = seed + 5)
let none_value = library::Option[int]::none()
print(describe_option(some_value))
print(describe_option(none_value))
